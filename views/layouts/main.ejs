<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- locals.title ? locals.title + ' - ' + globalSettings.shopName : globalSettings.shopName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body style="
    --shop-primary: <%= globalSettings.primaryColor %>; 
    --shop-btn-bg: <%= globalSettings.btnBgColor %>;
    --shop-btn-text: <%= globalSettings.btnTextColor %>;
    --sidebar-bg: <%= globalSettings.sidebarBgColor %>;
    --sidebar-text: <%= globalSettings.sidebarTextColor %>;
    --sidebar-link: <%= globalSettings.sidebarTextColor %>;
    --sidebar-hover: rgba(0,0,0,0.15);
    --sidebar-border: rgba(255,255,255,0.05);
    --sidebar-active-bg: <%= globalSettings.primaryColor %>;
    --sidebar-active-text: #ffffff;
">

    <div class="sidebar">
        <div class="sidebar-logo">
            <img src="<%= globalSettings.logoUrl || '/images/logo.png' %>" alt="<%= globalSettings.shopName %>" onerror="this.src='https://placehold.co/400x150/111/FFF?text=Shop+Logo'">
        </div>
        
        <div class="px-4 mb-2 mt-3 text-uppercase fw-bold small" style="font-size: 0.7rem; letter-spacing: 1px; color: rgba(255,255,255,0.5);">Main Menu</div>
        <div class="sidebar-nav">
            <div class="nav-item"><a href="/" class="nav-link"><i class="fa-solid fa-layer-group"></i> Overview</a></div>
            <div class="nav-item"><a href="#" class="nav-link"><i class="fa-regular fa-calendar"></i> Appointments</a></div>
            <div class="nav-item"><a href="/customers" class="nav-link"><i class="fa-solid fa-users"></i> Customers</a></div>
            <div class="nav-item"><a href="/vehicles" class="nav-link"><i class="fa-solid fa-car"></i> Vehicles</a></div>
            <div class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-file-invoice-dollar"></i> Estimates</a></div>
            <div class="nav-item"><a href="#" class="nav-link"><i class="fa-solid fa-clipboard-check"></i> Work Orders</a></div>
        </div>

        <div class="sidebar-footer">
            <button class="btn w-100 fw-bold" style="border: 1px solid var(--sidebar-link); color: var(--sidebar-text); opacity: 0.7;">Contact Support</button>
        </div>
    </div>

    <div class="main-content">
        <div class="topbar">
            <div class="d-flex align-items-center flex-grow-1">
                <div class="input-group" style="max-width: 400px;">
                    <span class="input-group-text bg-light border-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-0 shadow-none" placeholder="Search customers, vehicles, ROs...">
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light rounded-circle position-relative border-0 shadow-sm" style="width: 40px; height: 40px;">
                    <i class="fa-regular fa-bell text-muted"></i>
                </button>

                <% 
                    let initials = 'SA'; let fullName = 'System Admin'; let role = 'Manager'; let isManager = true;
                    if (typeof currentUser !== 'undefined' && currentUser) {
                        const fName = currentUser.firstName || 'System';
                        const lName = currentUser.lastName || 'Admin';
                        initials = fName.charAt(0).toUpperCase() + lName.charAt(0).toUpperCase();
                        fullName = fName + ' ' + lName;
                        role = currentUser.role || 'Manager';
                        isManager = (role === 'Manager');
                    }
                %>
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none text-dark dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold me-2 shadow-sm overflow-hidden" style="width: 35px; height: 35px; background-color: var(--shop-primary); color: var(--shop-btn-text) !important;">
                            <% if (typeof currentUser !== 'undefined' && currentUser.avatarUrl) { %>
                                <img src="<%= currentUser.avatarUrl %>" class="w-100 h-100" style="object-fit: cover;">
                            <% } else { %>
                                <%= initials %>
                            <% } %>
                        </div>

                        <div class="d-none d-md-block text-start" style="line-height: 1.2;">
                            <div class="fw-bold fs-6"><%= fullName %></div>
                            <div class="text-muted" style="font-size: 0.75rem;"><%= role %></div>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                        <li><a class="dropdown-item py-2 fw-semibold text-muted" href="/profile"><i class="fa-solid fa-user me-2"></i> My Profile</a></li>
                        <% if (isManager) { %>
                            <li><hr class="dropdown-divider"></li>
                            <li><h6 class="dropdown-header text-uppercase small fw-bold">Admin Controls</h6></li>
                            <li><a class="dropdown-item py-2 fw-semibold text-primary" href="/users"><i class="fa-solid fa-users-gear me-2"></i> Team Management</a></li>
                            <li><a class="dropdown-item py-2 fw-semibold text-primary" href="/settings"><i class="fa-solid fa-sliders me-2"></i> Shop Settings</a></li>
                        <% } %>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger fw-bold" href="/auth/logout"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Secure Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="content-area">
            <%- body %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%- typeof pageScripts !== 'undefined' ? pageScripts : '' %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/alerts.js"></script>
</body>
</html>