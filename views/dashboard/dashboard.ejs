<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Dashboard</h2>
            <p class="text-muted mb-0">Welcome back, here is what's happening at the shop today.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary fw-bold shadow-sm"><i class="fa-regular fa-calendar-plus me-2"></i> Book Appt</button>
            <button class="btn btn-primary fw-bold shadow-sm"><i class="fa-solid fa-plus me-2"></i> New Work Order</button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="rounded-3 d-flex align-items-center justify-content-center bg-primary shadow-sm me-3" style="width: 50px; height: 50px; color: var(--shop-btn-text) !important;">
                        <i class="fa-solid fa-clipboard-list fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Active Work Orders</h6>
                        <div class="d-flex align-items-center">
                            <h3 class="fw-bold mb-0 me-2">0</h3>
                            <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle"><i class="fa-solid fa-arrow-trend-up me-1"></i> Live</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="rounded-3 d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 50px; height: 50px; background-color: #10b981; color: #ffffff !important;">
                        <i class="fa-regular fa-calendar-check fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Today's Appointments</h6>
                        <div class="d-flex align-items-center">
                            <h3 class="fw-bold mb-0 me-2">0</h3>
                            <span class="text-muted small">No scheduled drop-offs</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="rounded-3 d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 50px; height: 50px; background-color: #f59e0b; color: #ffffff !important;">
                        <i class="fa-solid fa-car-side fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Vehicles in Shop</h6>
                        <div class="d-flex align-items-center">
                            <h3 class="fw-bold mb-0 me-2">0</h3>
                            <span class="text-muted small">Awaiting check-ins</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="card shadow-sm rounded-4 h-100" style="border: 2px solid #10b981;">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="rounded-3 d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 50px; height: 50px; background-color: #e6fcf5; color: #10b981 !important;">
                        <i class="fa-solid fa-server fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">System Status</h6>
                        <div class="d-flex align-items-center mb-1">
                            <h4 class="fw-bold text-success mb-0">Online</h4>
                        </div>
                        <span class="text-muted" style="font-size: 0.7rem;">MySQL connected via Sequelize</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>