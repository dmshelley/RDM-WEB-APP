<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">Team Management</h2>
            <p class="text-muted mb-0">Manage shop staff, roles, and system access</p>
        </div>
        <div>
            <a href="/users/create" class="btn btn-primary btn-lg fw-bold shadow-sm"><i class="fa-solid fa-user-plus me-2"></i> Add Staff Member</a>
        </div>
    </div>

    <% if (error) { %>
        <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation me-2"></i> <%= error %></div>
    <% } %>

    <% if (users && users.length > 0) { %>
        
        <% 
            const roleGroups = [
                { title: 'Management', role: 'Manager', icon: 'fa-user-tie', color: 'text-danger' },
                { title: 'Service Writers', role: 'Service Writer', icon: 'fa-headset', color: 'text-primary' },
                { title: 'Technicians', role: 'Technician', icon: 'fa-wrench', color: 'text-success' },
                { title: 'Read-Only Access', role: 'Read-Only', icon: 'fa-eye', color: 'text-secondary' }
            ];
        %>

        <% roleGroups.forEach(group => { %>
            <% const groupUsers = users.filter(u => u.role === group.role); %>
            
            <% if (groupUsers.length > 0) { %>
                <h5 class="fw-bold mb-3 mt-4 <%= group.color %>"><i class="fa-solid <%= group.icon %> me-2"></i><%= group.title %></h5>
                
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white mb-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 border-top">
                            <thead class="bg-light text-muted small text-uppercase fw-bold">
                                <tr>
                                    <th class="ps-4 py-3 border-bottom-0" style="font-weight: 600; width: 35%;">Staff Member</th>
                                    <th class="py-3 border-bottom-0" style="font-weight: 600; width: 35%;">Contact Email</th>
                                    <th class="py-3 border-bottom-0" style="font-weight: 600; width: 15%;">System Role</th>
                                    <th class="text-end pe-4 py-3 border-bottom-0" style="font-weight: 600; width: 15%;">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="border-top-0">
                                <% groupUsers.forEach(user => { %>
                                    <tr class="<%= user.isActive ? '' : 'opacity-50 bg-light' %>">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                
                                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm overflow-hidden" 
                                                     style="width: 45px; height: 45px; background-color: var(--shop-primary); color: var(--shop-btn-text) !important;">
                                                    <% if (user.avatarUrl) { %>
                                                        <img src="<%= user.avatarUrl %>" class="w-100 h-100" style="object-fit: cover;">
                                                    <% } else { %>
                                                        <%= user.firstName.charAt(0).toUpperCase() %><%= user.lastName.charAt(0).toUpperCase() %>
                                                    <% } %>
                                                </div>

                                                <div>
                                                    <div class="fw-bold text-dark fs-6">
                                                        <%= user.firstName %> <%= user.lastName %>
                                                        <% if (!user.isActive) { %>
                                                            <span class="badge bg-secondary ms-2 small">Inactive</span>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="text-muted fw-semibold"><i class="fa-regular fa-envelope me-2 text-secondary"></i><%= user.email %></div>
                                        </td>
                                        <td>
                                            <% 
                                                let badgeColor = 'bg-secondary';
                                                if (user.isActive) {
                                                    if (user.role === 'Manager') badgeColor = 'bg-danger';
                                                    if (user.role === 'Service Writer') badgeColor = 'bg-primary';
                                                    if (user.role === 'Technician') badgeColor = 'bg-success';
                                                }
                                            %>
                                            <span class="badge <%= badgeColor %> border shadow-sm px-3 py-2"><%= user.role %></span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a href="/users/<%= user.id %>/edit" class="btn btn-sm btn-light border text-dark shadow-sm fw-bold" title="Edit Staff">
                                                    <i class="fa-solid fa-pen"></i> Edit
                                                </a>
                                                
                                                <% if (user.id !== currentUser.id) { %>
                                                    <% if (user.isActive) { %>
                                                        <form action="/users/<%= user.id %>/deactivate" method="POST" class="d-inline" data-confirm="Revoke access for <%= user.firstName %> <%= user.lastName %>? They will no longer be able to log in.">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm fw-bold" title="Deactivate Account">
                                                                <i class="fa-solid fa-user-slash"></i>
                                                            </button>
                                                        </form>
                                                    <% } else { %>
                                                        <form action="/users/<%= user.id %>/reactivate" method="POST" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-success shadow-sm fw-bold" title="Restore Access">
                                                                <i class="fa-solid fa-user-check"></i> Restore
                                                            </button>
                                                        </form>
                                                    <% } %>
                                                <% } else { %>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary shadow-sm fw-bold disabled" title="You cannot deactivate yourself">
                                                        <i class="fa-solid fa-lock"></i>
                                                    </button>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } %>
        <% }) %>

    <% } else { %>
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
            <div class="card-body p-5 text-center text-muted">
                <i class="fa-solid fa-users fs-1 opacity-25 mb-3"></i>
                <h5 class="fw-bold text-dark">No staff found</h5>
            </div>
        </div>
    <% } %>
</div>