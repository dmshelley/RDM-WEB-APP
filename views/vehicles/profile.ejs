<div class="container-fluid p-0">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <a href="/vehicles" class="text-decoration-none text-muted small fw-semibold hover-primary"><i class="fa-solid fa-arrow-left me-1"></i> Back to Vehicles</a>
        </div>
        <div class="d-flex gap-2">
            <a href="/vehicles/<%= vehicle.id %>/edit" class="btn btn-light border shadow-sm fw-bold"><i class="fa-solid fa-pen text-muted me-1"></i> Edit Vehicle</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-body p-0">
                    <div class="p-4 text-center border-bottom bg-light">
                        <div class="rounded-3 mx-auto mb-3 bg-white border shadow-sm d-flex align-items-center justify-content-center p-3" style="width: 140px; height: 90px;">
                            <% const logoUrl = vehicle.safeDisplayImage || vehicle.imageUrl || vehicle.brandLogo; %>
                            <% if (logoUrl) { %>
                                <img src="<%= logoUrl %>" class="img-fluid object-fit-contain w-100 h-100" onerror="this.onerror=null; this.parentElement.innerHTML='<i class=\'fa-solid fa-car-side fs-1 opacity-25\'></i>';">
                            <% } else { %>
                                <i class="fa-solid fa-car-side fs-1 opacity-25"></i>
                            <% } %>
                        </div>
                        <h4 class="fw-bold mb-1">
                            <% if (vehicle.unitNumber) { %><span class="badge bg-primary align-middle me-2 fs-6">Unit #<%= vehicle.unitNumber %></span><% } %>
                            <%= vehicle.year %> <%= vehicle.make %>
                        </h4>
                        <h5 class="fw-semibold text-muted mb-3"><%= vehicle.model %> <%= vehicle.trim || '' %></h5>
                        
                        <div class="d-flex justify-content-center gap-2 mb-2">
                            <% if (vehicle.licensePlate) { %>
                                <span class="badge bg-warning text-dark font-monospace border border-warning-subtle shadow-sm px-3 py-2 fs-6"><%= vehicle.licensePlate.toUpperCase() %></span>
                            <% } else { %>
                                <span class="badge bg-light text-muted border px-3 py-2">No Plate Assigned</span>
                            <% } %>
                        </div>
                        <% if (vehicle.vin) { %>
                            <span class="badge bg-light text-dark border font-monospace px-3 py-2 mt-1"><i class="fa-solid fa-barcode text-muted me-2"></i><%= vehicle.vin %></span>
                        <% } %>
                    </div>
                    
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-uppercase text-muted fw-bold small mb-0">Mechanical Specifications</h6>
                            <% if (vehicle.productionDate) { %>
                                <span class="badge bg-light text-muted border shadow-sm" title="Build Date"><i class="fa-regular fa-calendar me-1"></i> Built <%= vehicle.productionDate %></span>
                            <% } %>
                        </div>
                        
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="bg-light rounded p-3 border h-100">
                                    <div class="small text-muted mb-1"><i class="fa-solid fa-gauge-high me-1"></i> Mileage</div>
                                    <div class="fw-bold text-dark"><%= vehicle.mileage ? vehicle.mileage.toLocaleString() + ' km' : 'Unknown' %></div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-3 border h-100">
                                    <div class="small text-muted mb-1"><i class="fa-solid fa-piston me-1 text-primary"></i> Engine</div>
                                    <div class="fw-bold text-dark"><%= vehicle.engineSize || 'Unknown' %></div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-3 border h-100">
                                    <div class="small text-muted mb-1"><i class="fa-solid fa-gears me-1"></i> Trans</div>
                                    <div class="fw-bold text-dark"><%= vehicle.transmission || 'Unknown' %></div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-3 border h-100">
                                    <div class="small text-muted mb-1"><i class="fa-solid fa-truck-monster me-1"></i> Drive</div>
                                    <div class="fw-bold text-dark"><%= vehicle.drivetrain || 'Unknown' %></div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-3 border h-100">
                                    <div class="small text-muted mb-1"><i class="fa-solid fa-gas-pump me-1"></i> Fuel</div>
                                    <div class="fw-bold text-dark"><%= vehicle.fuelType || 'Unknown' %></div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-3 border h-100">
                                    <div class="small text-muted mb-1"><i class="fa-solid fa-car me-1"></i> Body Style</div>
                                    <div class="fw-bold text-dark"><%= vehicle.bodyStyle || 'Unknown' %></div>
                                </div>
                            </div>
                            <div class="col-12 mt-2">
                                <div class="bg-light rounded p-3 border text-center">
                                    <div class="small text-muted mb-1"><i class="fa-solid fa-weight-scale me-1"></i> GVWR</div>
                                    <div class="fw-bold text-dark"><%= vehicle.weightClass || 'Unknown' %></div>
                                </div>
                            </div>
                        </div>

                        <% if (vehicle.notes) { %>
                            <hr class="my-4 text-muted opacity-25">
                            <h6 class="text-uppercase text-muted fw-bold small mb-2"><i class="fa-solid fa-wrench me-2"></i>Vehicle Notes</h6>
                            <div class="bg-light rounded p-3 text-dark small border shadow-sm">
                                <%= vehicle.notes %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7">
            
            <div class="card shadow-sm border-0 rounded-4 bg-white mb-4">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" 
                             style="width: 50px; height: 50px; background-color: var(--shop-primary); color: var(--shop-btn-text) !important; font-size: 1.2rem;">
                            <% if (vehicle.Customer) { %>
                                <%= vehicle.Customer.firstName.charAt(0).toUpperCase() %><%= vehicle.Customer.lastName.charAt(0).toUpperCase() %>
                            <% } else { %>
                                ?
                            <% } %>
                        </div>
                        <div>
                            <h6 class="text-uppercase text-muted fw-bold small mb-1">Registered Owner</h6>
                            <% if (vehicle.Customer) { %>
                                <h5 class="fw-bold text-dark mb-0"><%= vehicle.Customer.firstName %> <%= vehicle.Customer.lastName %></h5>
                                <div class="small text-muted mt-1"><i class="fa-solid fa-phone me-1"></i> <%= vehicle.Customer.phone %></div>
                            <% } else { %>
                                <h5 class="fw-bold text-muted mb-0 fst-italic">Unassigned</h5>
                            <% } %>
                        </div>
                    </div>
                    <% if (vehicle.Customer) { %>
                        <a href="/customers/<%= vehicle.customerId %>" class="btn btn-outline-primary fw-bold shadow-sm px-4">View Owner Profile</a>
                    <% } %>
                </div>
            </div>

            <div class="d-flex gap-3 mb-4">
                <button class="btn btn-primary flex-grow-1 fw-bold py-3 shadow-sm fs-5"><i class="fa-solid fa-clipboard-check me-2"></i> Start Work Order</button>
            </div>

            <h5 class="fw-bold mb-3"><i class="fa-solid fa-clipboard-list me-2 text-dark"></i>Service History</h5>
            <div class="card border border-dashed rounded-4 bg-transparent">
                <div class="card-body p-5 text-center text-muted">
                    <i class="fa-solid fa-folder-open fs-2 opacity-25 mb-3"></i>
                    <h6 class="fw-bold text-dark">No history found</h6>
                    <p class="small mb-0">Completed work orders for this vehicle will populate here.</p>
                </div>
            </div>
        </div>
    </div>
</div>