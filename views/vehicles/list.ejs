<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">Vehicles</h2>
            <p class="text-muted mb-0">Manage customer vehicles in the system</p>
        </div>
        
        <% if (can('create:vehicle')) { %>
            <div>
                <a href="/customers/create" class="btn btn-primary btn-lg fw-bold shadow-sm"><i class="fa-solid fa-plus me-2"></i> Add Vehicle Intake</a>
            </div>
        <% } %>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
        <% if (vehicles && vehicles.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 border-top">
                    <thead class="bg-light text-muted small text-uppercase fw-bold">
                        <tr>
                            <th class="ps-4 py-3 border-bottom-0" style="font-weight: 600;">Vehicle</th>
                            <th class="py-3 border-bottom-0" style="font-weight: 600;">Identification</th>
                            <th class="py-3 border-bottom-0" style="font-weight: 600;">Key Specs</th>
                            <th class="py-3 border-bottom-0" style="font-weight: 600;">Owner</th>
                            <th class="text-end pe-4 py-3 border-bottom-0" style="font-weight: 600;">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        <% vehicles.forEach(vehicle => { %>
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-3 d-flex align-items-center justify-content-center bg-white border shadow-sm me-3 p-2" 
                                             style="width: 50px; height: 50px; flex-shrink: 0;">
                                            <% const logoUrl = vehicle.safeDisplayImage || vehicle.imageUrl || vehicle.brandLogo; %>
                                            <% if (logoUrl) { %>
                                                <img src="<%= logoUrl %>" class="img-fluid object-fit-contain w-100 h-100" onerror="this.onerror=null; this.parentElement.innerHTML='<i class=\'fa-solid fa-car-side fs-5 opacity-25\'></i>';">
                                            <% } else { %>
                                                <i class="fa-solid fa-car-side fs-5 opacity-25"></i>
                                            <% } %>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark fs-6">
                                                <% if (vehicle.unitNumber) { %><span class="badge bg-primary me-1">#<%= vehicle.unitNumber %></span><% } %>
                                                <%= vehicle.year %> <%= vehicle.make %>
                                            </div>
                                            <div class="fw-semibold text-muted small"><%= vehicle.model %> <%= vehicle.trim || '' %></div>
                                        </div>
                                    </div>
                                </td>
                                
                                <td>
                                    <div class="d-flex flex-column gap-1 align-items-start">
                                        <% if (vehicle.licensePlate) { %>
                                            <span class="badge bg-warning text-dark font-monospace border border-warning-subtle px-2 py-1"><%= vehicle.licensePlate.toUpperCase() %></span>
                                        <% } else { %>
                                            <span class="badge bg-light text-muted border px-2 py-1">No Plate</span>
                                        <% } %>
                                        <% if (vehicle.vin) { %>
                                            <span class="badge bg-light text-dark border font-monospace px-2 py-1"><i class="fa-solid fa-barcode text-muted me-1"></i><%= vehicle.vin %></span>
                                        <% } %>
                                    </div>
                                </td>

                                <td>
                                    <% if (vehicle.engineSize) { %>
                                        <div class="fw-semibold text-dark small mb-1"><i class="fa-solid fa-piston me-1 text-primary"></i> <%= vehicle.engineSize %></div>
                                    <% } %>
                                    <div class="text-muted small d-flex gap-2">
                                        <% if (vehicle.drivetrain) { %><span><%= vehicle.drivetrain %></span><% } %>
                                        <% if (vehicle.transmission) { %><span>&bull; <%= vehicle.transmission %></span><% } %>
                                    </div>
                                </td>
                                
                                <td>
                                    <% if (vehicle.Customer) { %>
                                        <a href="/customers/<%= vehicle.customerId %>" class="text-decoration-none fw-bold text-primary hover-primary">
                                            <%= vehicle.Customer.firstName %> <%= vehicle.Customer.lastName %>
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted fst-italic small">Unassigned</span>
                                    <% } %>
                                </td>
                                
                                <td class="text-end pe-4">
                                    <a href="/vehicles/<%= vehicle.id %>" class="btn btn-sm btn-light border text-primary shadow-sm me-1" title="View Vehicle">
                                        <i class="fa-solid fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="card-body p-5 text-center text-muted my-4">
                <i class="fa-solid fa-warehouse fs-1 opacity-25 mb-3"></i>
                <h5 class="fw-bold text-dark">No vehicles found</h5>
                <p class="mb-4">Vehicles added during Customer Intake will automatically appear here.</p>
                
                <% if (can('create:vehicle')) { %>
                    <a href="/customers/create" class="btn btn-outline-primary fw-bold shadow-sm px-4">Add Customer & Vehicle</a>
                <% } %>
            </div>
        <% } %>
    </div>
</div>