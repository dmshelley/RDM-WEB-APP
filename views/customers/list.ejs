<div class="container-fluid p-0">
    
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">Customers</h2>
            <p class="text-muted mb-0">Manage your shop's client database</p>
        </div>
        
        <% if (can('create:customer')) { %>
            <div>
                <a href="/customers/create" class="btn btn-primary btn-lg fw-bold shadow-sm"><i class="fa-solid fa-plus me-2"></i> Add New Customer</a>
            </div>
        <% } %>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
        <% if (customers && customers.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 border-top">
                    <thead class="bg-light text-muted small text-uppercase fw-bold">
                        <tr>
                            <th class="ps-4 py-3 border-bottom-0" style="font-weight: 600;">Client Name</th>
                            <th class="py-3 border-bottom-0" style="font-weight: 600;">Contact Info</th>
                            <th class="py-3 border-bottom-0" style="font-weight: 600;">Location</th>
                            <th class="py-3 border-bottom-0" style="font-weight: 600;">Added</th>
                            <th class="text-end pe-4 py-3 border-bottom-0" style="font-weight: 600;">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        <% customers.forEach(customer => { %>
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm me-3" 
                                             style="width: 40px; height: 40px; background-color: var(--shop-primary); color: var(--shop-btn-text) !important; font-size: 0.9rem;">
                                            <%= customer.firstName.charAt(0).toUpperCase() %><%= customer.lastName.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark fs-6"><%= customer.firstName %> <%= customer.lastName %></div>
                                            <% if (customer.companyName) { %>
                                                <div class="small text-muted"><i class="fa-solid fa-building me-1 opacity-75"></i><%= customer.companyName %></div>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                                
                                <td>
                                    <div class="fw-semibold text-dark"><i class="fa-solid fa-phone me-2 text-muted small"></i><%= customer.phone %></div>
                                    <% if (customer.email) { %>
                                        <div class="small text-muted mt-1"><i class="fa-solid fa-envelope me-2 opacity-75"></i><%= customer.email %></div>
                                    <% } %>
                                </td>
                                
                                <td>
                                    <% if (customer.city || customer.province) { %>
                                        <div class="text-dark"><%= customer.city || 'Unknown' %>, <%= customer.province || '' %></div>
                                    <% } else { %>
                                        <span class="text-muted fst-italic small">Not provided</span>
                                    <% } %>
                                </td>
                                
                                <td class="text-muted small">
                                    <%= new Date(customer.created_at).toLocaleDateString('en-CA') %>
                                </td>
                                
                                <td class="text-end pe-4">
                                    <a href="/customers/<%= customer.id %>" class="btn btn-sm btn-light border text-primary shadow-sm me-1" title="View Profile">
                                        <i class="fa-solid fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="card-body p-5 text-center text-muted my-4">
                <i class="fa-solid fa-users fs-1 opacity-25 mb-3"></i>
                <h5 class="fw-bold text-dark">No customers found</h5>
                <p class="mb-4">Get started by adding your first shop customer and their vehicle.</p>
                
                <% if (can('create:customer')) { %>
                    <a href="/customers/create" class="btn btn-outline-primary fw-bold shadow-sm px-4">Add First Customer</a>
                <% } %>
            </div>
        <% } %>
    </div>
</div>