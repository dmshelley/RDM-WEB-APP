<div class="container-fluid p-0">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <a href="/customers" class="text-decoration-none text-muted small fw-semibold hover-primary"><i class="fa-solid fa-arrow-left me-1"></i> Back to Customers</a>
            <h2 class="fw-bold mt-2">Add New Customer</h2>
        </div>
    </div>

    <% if (error) { %>
        <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation me-2"></i> <%= error %></div>
    <% } %>

    <div class="card shadow-sm border-0 bg-transparent">
        <div class="card-header bg-white border-bottom pt-4 pb-0 px-4 rounded-top">
            <ul class="nav wizard-tabs" id="intakeTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="customer-tab" data-bs-toggle="pill" data-bs-target="#customer-pane" type="button" role="tab"><span class="wizard-step-num">1</span> Customer Details</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link disabled" id="vehicle-tab" data-bs-toggle="pill" data-bs-target="#vehicle-pane" type="button" role="tab"><span class="wizard-step-num">2</span> Primary Vehicle</button>
                </li>
            </ul>
        </div>

        <div class="card-body p-0 pt-4">
            <form action="/customers/create" method="POST" id="intakeForm">
                <div class="tab-content" id="intakeTabsContent">
                    
                    <div class="tab-pane fade show active" id="customer-pane" role="tabpanel" tabindex="0">
                        <div class="form-well">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-id-card me-2"></i>Personal Information</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-user text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control" id="firstName" name="firstName" placeholder="First Name" required>
                                            <label for="firstName">First Name <span class="text-danger">*</span></label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-regular fa-user text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control" id="lastName" name="lastName" placeholder="Last Name" required>
                                            <label for="lastName">Last Name <span class="text-danger">*</span></label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-building text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control" id="companyName" name="companyName" placeholder="Company/Fleet Name">
                                            <label for="companyName">Company / Fleet Name (Optional)</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-well">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-address-book me-2"></i>Contact Information</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <select class="form-select border-primary" id="contactPreference" name="contactPreference">
                                            <option value="Call" selected>Phone Call</option>
                                            <option value="Text">Text Message</option>
                                            <option value="Email">Email</option>
                                        </select>
                                        <label for="contactPreference" class="text-primary fw-bold">Preferred Method</label>
                                    </div>
                                </div>
                                <div class="col-md-8"></div>

                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-phone text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="tel" class="form-control fw-bold" id="phone" name="phone" placeholder="Primary Phone" required>
                                            <label for="phone">Primary Phone <span class="text-danger">*</span></label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-envelope text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="email" class="form-control" id="email" name="email" placeholder="Primary Email">
                                            <label for="email">Primary Email</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="additionalContactsContainer" class="mt-3"></div>
                            <button type="button" id="addContactBtn" class="btn btn-sm btn-light border text-primary fw-bold mt-3 shadow-sm"><i class="fa-solid fa-plus me-1"></i> Add Another Contact</button>
                        </div>

                        <div class="form-well">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-map-location-dot me-2"></i>Address (Optional)</h6>
                            <div class="row g-3">
                                <div class="col-12">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-location-dot text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control" id="address" name="address" placeholder="Street Address">
                                            <label for="address">Street Address</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="city" name="city" placeholder="City">
                                        <label for="city">City</label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <select class="form-select" id="province" name="province">
                                            <option value="AB" selected>Alberta</option>
                                            <option value="BC">British Columbia</option>
                                            <option value="SK">Saskatchewan</option>
                                            <option value="MB">Manitoba</option>
                                            <option value="ON">Ontario</option>
                                        </select>
                                        <label for="province">Province</label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control text-uppercase" id="postalCode" name="postalCode" placeholder="Postal Code">
                                        <label for="postalCode">Postal Code</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-well">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-clipboard me-2"></i>Customer Notes</h6>
                            <div class="form-floating">
                                <textarea class="form-control" placeholder="Preferences, fleet details, etc." id="customerNotes" name="customerNotes" style="height: 100px"></textarea>
                                <label for="customerNotes">Preferences, fleet details, etc.</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <button type="button" id="nextVehicleBtn" class="btn btn-primary btn-lg px-4 shadow-sm" disabled onclick="document.getElementById('vehicle-tab').click();">Next: Add Vehicle <i class="fa-solid fa-arrow-right ms-2"></i></button>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="vehicle-pane" role="tabpanel" tabindex="0">
                        <div class="form-well" style="background-color: #f8fafc; border-color: #e2e8f0;">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <label class="form-label fw-bold text-primary mb-2"><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Smart VIN Decoder</label>
                                    <div class="input-group input-group-lg shadow-sm">
                                        <span class="input-group-text bg-white text-primary"><i class="fa-solid fa-barcode"></i></span>
                                        <input type="text" class="form-control text-uppercase font-monospace border-start-0" id="vinInput" name="vin" maxlength="17" placeholder="Enter 17-digit VIN">
                                        <button class="btn btn-primary fw-bold px-4" type="button" id="decodeVinBtn" onclick="decodeVin()">Decode</button>
                                    </div>
                                    <small class="text-muted mt-2 d-block opacity-75">Automatically fetches Year, Make, Model, Engine, Fuel, and Body Type.</small>
                                </div>
                                <div class="col-md-4 text-end mt-3 mt-md-0">
                                    <input type="hidden" name="imageUrl" id="imageUrlInput">
                                    <div id="imagePlaceholder" class="bg-white border rounded d-inline-flex align-items-center justify-content-center text-muted shadow-sm" style="width: 140px; height: 90px;">
                                        <i class="fa-solid fa-car-side fs-1 opacity-50"></i>
                                    </div>
                                    <img id="vehicleImagePreview" src="" alt="Vehicle Preview" class="rounded object-fit-cover shadow border" style="width: 140px; height: 90px; display: none;">
                                </div>
                            </div>
                        </div>

                        <div class="form-well">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-car me-2"></i>Vehicle Identification</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" class="form-control fw-bold" id="yearInput" name="year" min="1900" max="2030" placeholder="Year">
                                        <label for="yearInput">Year</label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control fw-bold text-uppercase" id="makeInput" name="make" placeholder="Make">
                                        <label for="makeInput">Make</label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control fw-bold text-uppercase" id="modelInput" name="model" placeholder="Model">
                                        <label for="modelInput">Model</label>
                                    </div>
                                </div>
                                
                                <div class="col-md-6 mt-4">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-hashtag text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control border-start-0 ps-0 text-uppercase" id="licensePlate" name="licensePlate" placeholder="License Plate">
                                            <label for="licensePlate">License Plate</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 mt-4">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-palette text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control border-start-0 ps-0" id="color" name="color" placeholder="Color">
                                            <label for="color">Exterior Color</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-well">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-gears me-2"></i>Mechanical Specifications</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="input-group">
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control fw-bold text-danger" id="mileage" name="mileage" placeholder="Mileage" required>
                                            <label for="mileage">Current Mileage <span class="text-danger">*</span></label>
                                        </div>
                                        <span class="input-group-text bg-light text-muted">km</span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fa-solid fa-piston text-muted"></i></span>
                                        <div class="form-floating flex-grow-1">
                                            <input type="text" class="form-control text-uppercase" id="engineSize" name="engineSize" placeholder="Engine Size">
                                            <label for="engineSize">Engine Size</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="transmission" name="transmission" placeholder="Transmission">
                                        <label for="transmission">Transmission</label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="drivetrain" name="drivetrain" placeholder="Drivetrain">
                                        <label for="drivetrain">Drivetrain</label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="fuelType" name="fuelType" placeholder="Fuel Type">
                                        <label for="fuelType">Fuel Type</label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="bodyStyle" name="bodyStyle" placeholder="Body Style">
                                        <label for="bodyStyle">Body Style</label>
                                    </div>
                                </div>
                                <div class="col-12 mt-3">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="weightClass" name="weightClass" placeholder="GVWR Weight Class">
                                        <label for="weightClass">GVWR / Weight Class</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-well">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-wrench me-2"></i>Vehicle Notes</h6>
                            <div class="form-floating">
                                <textarea class="form-control" placeholder="Existing damage, quirks, etc." id="vehicleNotes" name="vehicleNotes" style="height: 100px"></textarea>
                                <label for="vehicleNotes">Existing damage, quirks, etc.</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <button type="button" class="btn btn-light border text-dark shadow-sm px-4" onclick="document.getElementById('customer-tab').click();"><i class="fa-solid fa-arrow-left me-2"></i> Back</button>
                            <button type="submit" id="submitIntakeBtn" class="btn btn-primary btn-lg px-4 shadow-sm"><i class="fa-solid fa-check me-2"></i> Save Complete Intake</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://unpkg.com/imask"></script>
<script src="/js/intake.js?v=4"></script>