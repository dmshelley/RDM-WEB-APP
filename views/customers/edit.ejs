<div class="container-fluid p-0">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <a href="/customers/<%= customer.id %>" class="text-decoration-none text-muted small fw-semibold hover-primary"><i class="fa-solid fa-arrow-left me-1"></i> Back to Profile</a>
            <h2 class="fw-bold mt-2">Edit Customer</h2>
        </div>
    </div>

    <% if (error) { %>
        <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation me-2"></i> <%= error %></div>
    <% } %>

    <div class="card shadow-sm border-0 rounded-4 bg-transparent">
        <div class="card-body p-0">
            <form action="/customers/<%= customer.id %>/edit" method="POST" id="editCustomerForm">
                
                <div class="form-well">
                    <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-id-card me-2"></i>Personal Information</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-user text-muted"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input type="text" class="form-control" id="firstName" name="firstName" placeholder="First Name" value="<%= customer.firstName %>" required>
                                    <label for="firstName">First Name <span class="text-danger">*</span></label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-regular fa-user text-muted"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input type="text" class="form-control" id="lastName" name="lastName" placeholder="Last Name" value="<%= customer.lastName %>" required>
                                    <label for="lastName">Last Name <span class="text-danger">*</span></label>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-building text-muted"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input type="text" class="form-control" id="companyName" name="companyName" placeholder="Company/Fleet Name" value="<%= customer.companyName || '' %>">
                                    <label for="companyName">Company / Fleet Name (Optional)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-well">
                    <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-address-book me-2"></i>Contact Information</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-floating">
                                <select class="form-select border-primary" id="contactPreference" name="contactPreference">
                                    <option value="Call" <%= customer.contactPreference === 'Call' ? 'selected' : '' %>>Phone Call</option>
                                    <option value="Text" <%= customer.contactPreference === 'Text' ? 'selected' : '' %>>Text Message</option>
                                    <option value="Email" <%= customer.contactPreference === 'Email' ? 'selected' : '' %>>Email</option>
                                </select>
                                <label for="contactPreference" class="text-primary fw-bold">Preferred Method</label>
                            </div>
                        </div>
                        <div class="col-md-8"></div>

                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-phone text-muted"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input type="tel" class="form-control fw-bold" id="phone" name="phone" placeholder="Primary Phone" value="<%= customer.phone %>" required>
                                    <label for="phone">Primary Phone <span class="text-danger">*</span></label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-envelope text-muted"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input type="email" class="form-control" id="email" name="email" placeholder="Primary Email" value="<%= customer.email || '' %>">
                                    <label for="email">Primary Email</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% 
                        let parsedContacts = [];
                        if (customer.additionalContacts) {
                            try {
                                parsedContacts = typeof customer.additionalContacts === 'string' ? JSON.parse(customer.additionalContacts) : customer.additionalContacts;
                            } catch (e) {}
                        }
                    %>
                    <div id="additionalContactsContainer" class="mt-3">
                        <% parsedContacts.forEach(contact => { %>
                            <div class="row g-2 mt-2 align-items-center additional-contact-row">
                                <div class="col-md-3">
                                    <select name="contactType" class="form-select text-muted">
                                        <option value="Phone" <%= contact.type === 'Phone' ? 'selected' : '' %>>Phone</option>
                                        <option value="Email" <%= contact.type === 'Email' ? 'selected' : '' %>>Email</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <input type="text" name="contactLabel" class="form-control" placeholder="Label (e.g. Wife's Cell)" value="<%= contact.label %>">
                                </div>
                                <div class="col-md-5">
                                    <input type="text" name="contactValue" class="form-control dynamic-value" placeholder="Number or Address" value="<%= contact.value %>" required>
                                </div>
                                <div class="col-md-1 text-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm remove-contact" title="Remove"><i class="fa-solid fa-xmark"></i></button>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                    
                    <button type="button" id="addContactBtn" class="btn btn-sm btn-light border text-primary fw-bold mt-3 shadow-sm"><i class="fa-solid fa-plus me-1"></i> Add Another Contact</button>
                </div>

                <div class="form-well">
                    <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-map-location-dot me-2"></i>Address</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-location-dot text-muted"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input type="text" class="form-control" id="address" name="address" placeholder="Street Address" value="<%= customer.address || '' %>">
                                    <label for="address">Street Address</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="city" name="city" placeholder="City" value="<%= customer.city || '' %>">
                                <label for="city">City</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <select class="form-select" id="province" name="province">
                                    <option value="AB" <%= customer.province === 'AB' ? 'selected' : '' %>>Alberta</option>
                                    <option value="BC" <%= customer.province === 'BC' ? 'selected' : '' %>>British Columbia</option>
                                    <option value="SK" <%= customer.province === 'SK' ? 'selected' : '' %>>Saskatchewan</option>
                                    <option value="MB" <%= customer.province === 'MB' ? 'selected' : '' %>>Manitoba</option>
                                    <option value="ON" <%= customer.province === 'ON' ? 'selected' : '' %>>Ontario</option>
                                </select>
                                <label for="province">Province</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control text-uppercase" id="postalCode" name="postalCode" placeholder="Postal Code" value="<%= customer.postalCode || '' %>">
                                <label for="postalCode">Postal Code</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-well">
                    <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-clipboard me-2"></i>Customer Notes</h6>
                    <div class="form-floating">
                        <textarea class="form-control" placeholder="Preferences, fleet details, etc." id="notes" name="notes" style="height: 120px"><%= customer.notes || '' %></textarea>
                        <label for="notes">Preferences, fleet details, etc.</label>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4 mb-5">
                    <button type="button" class="btn btn-outline-danger shadow-sm px-4 fw-bold" onclick="if(confirm('Are you sure you want to delete this customer? This cannot be undone.')) { document.getElementById('deleteForm').submit(); }"><i class="fa-solid fa-trash me-2"></i> Delete Customer</button>
                    <button type="submit" id="saveBtn" class="btn btn-primary btn-lg px-5 shadow-sm fw-bold"><i class="fa-solid fa-check me-2"></i> Save Changes</button>
                </div>
            </form>

            <form action="/customers/<%= customer.id %>/delete" method="POST" id="deleteForm" style="display: none;"></form>
        </div>
    </div>
</div>

<script src="https://unpkg.com/imask"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // 1. Static Masks
        const phoneInput = document.getElementById('phone');
        if (phoneInput) IMask(phoneInput, { mask: '(000) 000-0000' });
        
        const postalInput = document.getElementById('postalCode');
        if (postalInput) IMask(postalInput, { mask: 'a0a 0a0', prepare: str => str.toUpperCase() });

        // 2. Pre-loaded Dynamic Rows Activation
        document.querySelectorAll('.additional-contact-row').forEach(row => {
            const select = row.querySelector('select');
            const input = row.querySelector('.dynamic-value');
            let mask;
            if (select.value === 'Phone') mask = IMask(input, { mask: '(000) 000-0000' });

            select.addEventListener('change', (e) => {
                if (e.target.value === 'Email') {
                    if (mask) mask.destroy();
                    input.placeholder = 'Email Address';
                } else {
                    input.placeholder = 'Phone Number';
                    mask = IMask(input, { mask: '(000) 000-0000' });
                }
            });
            row.querySelector('.remove-contact').addEventListener('click', () => row.remove());
        });

        // 3. Add New Row Button
        const addContactBtn = document.getElementById('addContactBtn');
        const container = document.getElementById('additionalContactsContainer');
        if (addContactBtn && container) {
            addContactBtn.addEventListener('click', () => {
                const row = document.createElement('div');
                row.className = 'row g-2 mt-2 align-items-center additional-contact-row';
                row.innerHTML = `
                    <div class="col-md-3">
                        <select name="contactType" class="form-select text-muted">
                            <option value="Phone">Phone</option>
                            <option value="Email">Email</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input type="text" name="contactLabel" class="form-control" placeholder="Label (e.g. Wife's Cell)">
                    </div>
                    <div class="col-md-5">
                        <input type="text" name="contactValue" class="form-control dynamic-value" placeholder="Number or Address" required>
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-outline-danger btn-sm remove-contact" title="Remove"><i class="fa-solid fa-xmark"></i></button>
                    </div>
                `;
                container.appendChild(row);

                const select = row.querySelector('select');
                const input = row.querySelector('.dynamic-value');
                let mask = IMask(input, { mask: '(000) 000-0000' });

                select.addEventListener('change', (e) => {
                    if (e.target.value === 'Email') {
                        if (mask) mask.destroy();
                        input.value = '';
                        input.placeholder = 'Email Address';
                    } else {
                        input.value = '';
                        input.placeholder = 'Phone Number';
                        mask = IMask(input, { mask: '(000) 000-0000' });
                    }
                });

                row.querySelector('.remove-contact').addEventListener('click', () => row.remove());
            });
        }

        // 4. Submit Animation
        document.getElementById('editCustomerForm').addEventListener('submit', function() {
            const btn = document.getElementById('saveBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> Saving...';
        });
    });
</script>